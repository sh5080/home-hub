{
  "name": "home-hub",
  "version": "0.1.0",
  "private": true,
  "description": "IoT central control hub — HomeKit bridge with pluggable device adapters",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@nestjs/core"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter hub dev",
    "build": "pnpm --filter hub build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @home-hub/db generate",
    "db:migrate": "pnpm --filter @home-hub/db migrate"
  }
}
